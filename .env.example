# ─────────────────────────────────────────────────────────────
# Artifex — generation provider configuration
# Copy this file to `.env.local` and fill in the values you need.
# With NO keys set, Artifex runs in fully-working MOCK mode so you
# can develop and demo the entire product offline, for free.
# ─────────────────────────────────────────────────────────────

# Which provider to use for asset generation.
# Options: "mock" (default, no key needed) | "openai" | "replicate"
GENERATION_PROVIDER=mock

# ── OpenAI-compatible image generation (used when provider=openai) ──
# Works with OpenAI or any OpenAI-compatible image endpoint.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
# Optional: override the base URL for OpenAI-compatible providers.
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Replicate (used when provider=replicate) ──
# Good for both image models and image-to-3D (GLB) models.
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-schnell

# ─────────────────────────────────────────────────────────────
# Accounts (Auth.js) — optional. Without these, the app runs in
# demo mode with no sign-in. Add them to enable GitHub accounts.
# ─────────────────────────────────────────────────────────────
# Generate a secret with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
# Create a GitHub OAuth app: https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─────────────────────────────────────────────────────────────
# Persistence (Supabase) — optional. Run supabase/schema.sql first.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Billing (Stripe) — optional. Create 3 one-time Prices and paste
# their ids below. Webhook event: checkout.session.completed
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=

# Public base URL used for Stripe redirect URLs (set in production).
NEXT_PUBLIC_APP_URL=http://localhost:3000
